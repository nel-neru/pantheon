# RepoCorp AI Environment Variables
# Copy this file to .env and set only the providers you plan to use.

# LLM providers (pick at least one)
# RepoCorp defaults to Anthropic unless REPOCORP_DEFAULT_LLM_PROVIDER is set.
REPOCORP_DEFAULT_LLM_PROVIDER=anthropic
# REPOCORP_DEFAULT_MODEL=claude-3-5-sonnet-20241022

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GOOGLE_API_KEY=AIza...

# GitHub (required for real repo integration / PR creation)
GITHUB_TOKEN=ghp_...

# Optional: LangSmith / observability
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=...

# RepoCorp specific
REPOCORP_LOG_LEVEL=INFO
REPOCORP_MAX_ORGS=10
