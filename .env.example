# RepoCorp AI Environment Variables
# Copy this file to .env and fill in your keys

# LLM Providers (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
# OLLAMA_BASE_URL=http://localhost:11434

# GitHub (required for real repo integration)
GITHUB_TOKEN=ghp_...

# Optional: LangSmith / observability
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=...

# RepoCorp specific
REPOCORP_LOG_LEVEL=INFO
REPOCORP_MAX_ORGS=10
