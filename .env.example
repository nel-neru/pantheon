# RepoCorp AI Environment Variables
# Copy this file to .env and set only the providers you plan to use.

# LLM providers (pick at least one)
# RepoCorp defaults to Anthropic unless REPOCORP_DEFAULT_LLM_PROVIDER is set.
REPOCORP_DEFAULT_LLM_PROVIDER=anthropic
# REPOCORP_DEFAULT_MODEL=claude-3-5-sonnet-20241022

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GOOGLE_API_KEY=AIza...

# GitHub (required for real repo integration / PR creation)
GITHUB_TOKEN=ghp_...

# Optional: LangSmith / observability
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=...

# RepoCorp specific
REPOCORP_LOG_LEVEL=INFO
REPOCORP_MAX_ORGS=10

# --- Server / security (all optional; safe defaults) ---
# Bind address. Default 127.0.0.1 (localhost only). Set 0.0.0.0 to expose (trusted LAN only).
# REPOCORP_HOST=127.0.0.1
# Comma-separated extra allowed Host headers when exposing on LAN (DNS-rebinding guard, A4).
# REPOCORP_ALLOWED_HOSTS=
# Comma-separated allowed CORS origins (A3). Default http://localhost:5173.
# REPOCORP_CORS_ORIGINS=
# Optional local API token (A2). When set, /api/* (except /api/health) requires it.
# REPOCORP_API_TOKEN=
# Max request body bytes (A8). Default 10485760 (10 MiB).
# REPOCORP_MAX_BODY_BYTES=10485760
# Max concurrent /ws/updates connections (A9). 0 = unlimited. Default 50.
# REPOCORP_WS_MAX_CONNECTIONS=50

# --- Observability (optional) ---
# Structured JSON logs (J2): set to "json". Default text.
# REPOCORP_LOG_FORMAT=text

# --- Embedded terminal GC (optional, C1) ---
# REPOCORP_TERMINAL_IDLE_TTL=3600
# REPOCORP_TERMINAL_EXITED_TTL=300
