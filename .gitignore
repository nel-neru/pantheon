# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS
.DS_Store
Thumbs.db

# Environment / Secrets
# The Stop-hook auto-commit pushes work branches to a (possibly public) remote every turn, so any
# secret reaching the tree must be ignored. Patterns are credential-SHAPED (extensions / known
# names), NOT broad substrings, so source like `secret_manager.py` / `test_secrets.py` stays tracked.
# (The auto-commit hook additionally un-stages any secret-shaped file via .claude/hooks/sensitive-paths.mjs.)
.env
.env.*
*.env
!.env.example
!.env.sample
!.env.template
*.pem
*.key
*.pfx
*.p12
*.p8
*.jks
*.keystore
*.ppk
*.asc
id_rsa
id_dsa
id_ecdsa
id_ed25519
.npmrc
.git-credentials
.pgpass
.netrc
.pypirc
secrets.json
secret.json
credentials.json
secrets.yaml
secrets.yml
.secrets
service-account*.json
gcp-*.json
aws-*.json

# pytest / ruff / mypy
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Node.js (web/frontend)
node_modules/
web/frontend/dist/
web/frontend/.vite/
*.tsbuildinfo

# Pantheon runtime state (per-repo): sessions, indexes, caches
.pantheon/
# Reset/backup variants of the runtime-state dir (e.g. .pantheon.reset-bak-<timestamp>/);
# like .pantheon/ these are transient state and must never be swept into auto-commits.
.pantheon.*

# Claude Code — share project config (.claude/settings.json, agents, skills,
# commands, rules, hooks, .mcp.json) but keep personal/secret bits local.
.claude/settings.local.json
.claude/.credentials.json

# Codex live shell-env config is machine-specific (absolute paths); only the
# portable .codex/config.toml.example is tracked.
.codex/config.toml

# Misc
*.log
*.bak
*.tmp

# ジャンル別に自動生成される組織テンプレート（pantheon org create の出力、ユーザー固有）
config/departments/generated/*.yaml
!config/departments/generated/.gitkeep

# 一時作業ディレクトリ（レビュー成果物・スクラッチ。auto-commit による誤追跡を防ぐ）
tmp/
