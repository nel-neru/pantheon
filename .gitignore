# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS
.DS_Store
Thumbs.db

# Environment / Secrets
.env
.env.local
.env.production
.env.*.local

# pytest / ruff / mypy
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Node.js (web/frontend)
node_modules/
web/frontend/dist/
web/frontend/.vite/

# Pantheon runtime state (per-repo): sessions, indexes, caches
.pantheon/

# Claude Code — share project config (.claude/settings.json, agents, skills,
# commands, rules, hooks, .mcp.json) but keep personal/secret bits local.
.claude/settings.local.json
.claude/.credentials.json

# Misc
*.log
*.bak
*.tmp

# ジャンル別に自動生成される組織テンプレート（pantheon org create の出力、ユーザー固有）
config/departments/generated/*.yaml
!config/departments/generated/.gitkeep
